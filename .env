# Database
database_url=postgresql://user:password@localhost:5432/yourdb

# JWT Security - CHANGE THESE IN PRODUCTION!
SECRET_KEY=your-super-secret-min-32-char-key-change-in-production-abc123xyz
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# App config
enable_strict_idempotency_check=false
transaction_settlement_window=0.0
enable_graceful_degradation=false
wallet_operation_lock_timeout=5000